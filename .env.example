# ===========================
# Vaanix Environment Variables
# ===========================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="postgresql://neondb_owner:npg_9aj1NSyEFqWG@ep-restless-glade-a1auscch.ap-southeast-1.aws.neon.tech/vaanix_db?sslmode=require&channel_binding=require"

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Backend API ---
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# --- Redis (Upstash) ---
REDIS_URL="redis://default:password@host.upstash.io:6379"

# --- AI Providers (Plug & Play) ---
# Global defaults — swap provider by changing these values
LLM_PROVIDER="openai"          # openai | google | azure
LLM_MODEL="gpt-4o-mini"        # default model (overridable per-agent)
EMBEDDING_PROVIDER="openai"    # openai | azure
EMBEDDING_MODEL="text-embedding-3-small"

# Provider API Keys (only the active providers need keys)
OPENAI_API_KEY="sk-..."
GOOGLE_AI_API_KEY="AIza..."
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""       # https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# --- Vector Store (Storage & Retrieval) ---
# Global default — swap provider by changing this value
VECTOR_STORE_PROVIDER="pgvector"   # pgvector | pinecone | qdrant

# Vector Store API Keys & Config
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX=""

QDRANT_URL=""
QDRANT_API_KEY=""

# Knowledge Base Processing
KNOWLEDGE_CHUNK_SIZE=1500
KNOWLEDGE_CHUNK_OVERLAP=200

# --- Node Environment ---
NODE_ENV="development"

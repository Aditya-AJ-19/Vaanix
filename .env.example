# ===========================
# Vaanix Environment Variables
# ===========================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="neon database url"

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Backend API ---
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# --- Redis (Upstash) ---
REDIS_URL="redis://default:password@host.upstash.io:6379"

# --- AI Providers (Plug & Play) ---
# Global defaults — swap provider by changing these values
LLM_PROVIDER="openai"          # openai | google | azure
LLM_MODEL="gpt-4o-mini"        # default model (overridable per-agent)
EMBEDDING_PROVIDER="openai"    # openai | azure
EMBEDDING_MODEL="text-embedding-3-small"

# Provider API Keys (only the active providers need keys)
OPENAI_API_KEY="sk-..."
GOOGLE_AI_API_KEY="AIza..."
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""       # https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION="2024-08-01-preview"
TOGETHER_API_KEY=""            # https://api.together.xyz

# NVIDIA NIM / OpenAI-compatible endpoints
NVIDIA_API_KEY=""              # https://build.nvidia.com
NVIDIA_EMBEDDING_MODEL=""      # e.g. nvidia/llama-nemotron-embed-1b-v2
NVIDIA_EMBEDDING_INPUT_TYPE="passage"   # 'passage' for docs, 'query' at runtime

# Model overrides (per embedding endpoint)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_BASE_URL=""   # Leave blank to use official OpenAI endpoint

# --- Vector Store (Storage & Retrieval) ---
# Global default — swap provider by changing this value
VECTOR_STORE_PROVIDER="pgvector"   # pgvector | pinecone | qdrant

# Vector Store API Keys & Config
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX=""

QDRANT_URL=""
QDRANT_API_KEY=""

# Knowledge Base Processing
KNOWLEDGE_CHUNK_SIZE=1500
KNOWLEDGE_CHUNK_OVERLAP=200

# --- Node Environment ---
NODE_ENV="development"
